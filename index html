<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>26/27 Table Predictor — Ranking Engine</title>
<style>
  :root{
    --ink:#0d0b1a;
    --panel:#171432;
    --panel2:#1f1a40;
    --line:#332c5c;
    --pl-magenta:#f01e6d;
    --pl-violet:#7a3cf5;
    --pl-cyan:#2fe0d6;
    --text:#f4f2fb;
    --muted:#9d97c2;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      radial-gradient(1200px 600px at 15% -10%, rgba(122,60,245,.35), transparent 60%),
      radial-gradient(1000px 500px at 100% 0%, rgba(240,30,109,.25), transparent 55%),
      var(--ink);
    color:var(--text);
    font-family: 'Segoe UI', system-ui, -apple-system, Roboto, Helvetica, Arial, sans-serif;
    min-height:100vh;
  }
  .wrap{max-width:640px;margin:0 auto;padding:20px 16px 80px;}

  .brand{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
  .brand h1{font-size:15px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin:0;}
  .brand .dot{width:8px;height:8px;border-radius:50%;background:var(--pl-cyan);display:inline-block;margin-right:8px;box-shadow:0 0 12px var(--pl-cyan);}
  .pl-header-logo{height:16px;width:auto;vertical-align:-3px;margin-right:6px;}
  .brand-right{display:flex;align-items:center;gap:10px;}
  .edit-icon-btn{
    width:30px;height:30px;border-radius:8px;border:1px solid var(--line);background:var(--panel);
    color:var(--muted);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;
    flex-shrink:0;line-height:1;padding:0;
  }
  .edit-icon-btn:hover{color:var(--text);border-color:var(--pl-cyan);}

  /* ---------- Screens ---------- */
  .screen{display:none;}
  .screen.active{display:block;animation:fade .25s ease;}
  @keyframes fade{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

  h2.title{font-size:28px;line-height:1.15;margin:6px 0 8px;font-weight:800;letter-spacing:-.01em;}
  p.sub{color:var(--muted);font-size:15px;line-height:1.5;margin:0 0 24px;}

  /* Welcome */
  .card{
    background:linear-gradient(180deg,var(--panel2),var(--panel));
    border:1px solid var(--line);
    border-radius:18px;
    padding:22px;
  }
  select, input[type=text]{
    width:100%;padding:14px 16px;border-radius:12px;border:1px solid var(--line);
    background:#120f26;color:var(--text);font-size:16px;margin-top:6px;
    appearance:none;
  }
  label.field{display:block;font-size:12px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-top:16px;font-weight:700;}
  .btn{
    display:block;width:100%;text-align:center;padding:16px;border-radius:14px;border:none;
    font-size:16px;font-weight:800;cursor:pointer;margin-top:22px;letter-spacing:.01em;
    background:linear-gradient(90deg,var(--pl-magenta),var(--pl-violet));
    color:white;box-shadow:0 8px 24px -8px rgba(240,30,109,.6);
  }
  .btn:active{transform:scale(.98);}
  .btn.secondary{
    background:transparent;border:1px solid var(--line);color:var(--text);box-shadow:none;
  }
  .btn.ghost{background:transparent;border:none;color:var(--muted);box-shadow:none;text-decoration:underline;font-weight:600;}
  .btn.white{
    background:#ffffff;color:var(--ink);border:1px solid var(--line);box-shadow:none;
  }
  .btn.white:hover{background:#f0eefa;}

  /* Progress */
  .progress-row{display:flex;align-items:center;gap:10px;margin-bottom:22px;}
  .progress-track{flex:1;height:6px;border-radius:6px;background:var(--panel2);overflow:hidden;}
  .progress-fill{height:100%;background:linear-gradient(90deg,var(--pl-cyan),var(--pl-violet));border-radius:6px;transition:width .3s ease;}
  .progress-label{font-size:12px;color:var(--muted);white-space:nowrap;font-weight:700;}

  /* Compare */
  .vs-wrap{display:flex;align-items:stretch;gap:12px;}
  .team-card{
    flex:1;background:var(--panel);border:1px solid var(--line);border-radius:18px;
    padding:24px 14px;display:flex;flex-direction:column;align-items:center;justify-content:center;
    cursor:pointer;transition:transform .12s ease, border-color .12s ease, background .12s ease;
    min-height:220px;gap:14px;
  }
  .team-card:active{transform:scale(.96);}
  .team-card:hover{border-color:var(--pl-cyan);background:var(--panel2);}
  .team-card img{width:76px;height:76px;object-fit:contain;filter:drop-shadow(0 4px 10px rgba(0,0,0,.4));}
  .team-card .name{font-weight:800;font-size:15px;text-align:center;line-height:1.25;}
  .team-card .prior{font-size:12px;color:var(--muted);}

  .vs-badge{
    align-self:center;width:36px;height:36px;border-radius:50%;background:var(--ink);
    border:1px solid var(--line);display:flex;align-items:center;justify-content:center;
    font-size:11px;font-weight:800;color:var(--muted);flex-shrink:0;
  }

  .too-close{width:100%;margin-top:14px;padding:12px;border-radius:12px;border:1px dashed var(--line);
    background:transparent;color:var(--muted);font-size:13px;cursor:pointer;}
  .too-close:hover{color:var(--text);border-color:var(--muted);}

  .undo-row{display:flex;justify-content:center;margin-top:18px;}
  .undo-row button{background:none;border:none;color:var(--muted);font-size:13px;cursor:pointer;text-decoration:underline;}

  /* Results */
  .result-list{list-style:none;margin:0;padding:0;}
  .result-row{
    display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:12px;
    background:var(--panel);border:1px solid var(--line);margin-bottom:8px;
  }
  .result-row .pos{width:24px;text-align:center;font-weight:800;color:var(--muted);font-size:14px;flex-shrink:0;}
  .result-row img{width:28px;height:28px;object-fit:contain;flex-shrink:0;}
  .result-row .rname{flex:1;font-weight:700;font-size:14px;min-width:0;}
  .result-row .diff{font-size:11px;font-weight:700;padding:2px 7px;border-radius:20px;flex-shrink:0;}
  .diff.up{color:#2fe08a;background:rgba(47,224,138,.12);}
  .diff.down{color:#f05b5b;background:rgba(240,91,91,.12);}
  .diff.same{color:var(--muted);background:rgba(157,151,194,.12);}

  .zone-1{border-left:3px solid #2fe0d6;}
  .zone-euro{border-left:3px solid #7a3cf5;}
  .zone-relegation{border-left:3px solid #f05b5b;}

  .reorder-btns{display:flex;flex-direction:column;gap:2px;flex-shrink:0;}
  .reorder-btns button{
    width:26px;height:22px;border-radius:6px;border:1px solid var(--line);background:#120f26;
    color:var(--text);font-size:11px;cursor:pointer;line-height:1;display:flex;align-items:center;justify-content:center;
  }
  .reorder-btns button:disabled{opacity:.25;cursor:default;}
  .reorder-btns button:not(:disabled):hover{border-color:var(--pl-cyan);}

  .edit-hint{font-size:12px;color:var(--muted);margin:-6px 0 14px;}
  .efl-results-title{font-size:16px;font-weight:800;margin:20px 0 4px;}

  .lock-box{margin-top:24px;}
  .row2{display:flex;gap:10px;margin-top:10px;}
  .row2 .btn{margin-top:0;}
  .lock-status{text-align:center;font-size:13px;color:var(--muted);margin-top:10px;min-height:18px;}

  .stat-strip{display:flex;gap:8px;margin-bottom:18px;}
  .stat-pill{flex:1;background:var(--panel);border:1px solid var(--line);border-radius:12px;padding:10px;text-align:center;}
  .stat-pill b{display:block;font-size:18px;}
  .stat-pill span{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;}

  footer{text-align:center;color:var(--muted);font-size:11px;margin-top:40px;}

  /* EFL bonus screen */
  .efl-block{
    background:var(--panel);border:1px solid var(--line);border-radius:14px;
    padding:14px;margin-bottom:12px;border-left:4px solid var(--line);
  }
  .efl-header{margin-bottom:10px;display:flex;align-items:center;gap:8px;}
  .efl-logo-svg{width:20px;height:23px;flex-shrink:0;display:block;}
  .efl-logo{height:20px;max-width:130px;object-fit:contain;flex-shrink:0;}
  .efl-badge{
    display:inline-block;font-size:12px;font-weight:800;letter-spacing:.04em;
    padding:4px 10px;border-radius:20px;color:#fff;
  }
  .efl-championship{border-left-color:#D4AF37;}
  .efl-championship .efl-badge{background:#D4AF37;color:#231a00;}
  .efl-league1{border-left-color:#C7C9D9;}
  .efl-league1 .efl-badge{background:#C7C9D9;color:#20202c;}
  .efl-league2{border-left-color:#C8102E;}
  .efl-league2 .efl-badge{background:#C8102E;color:#fff;}
  .efl-carabao{border-left-color:#1FA855;}
  .efl-carabao .efl-badge{background:#1FA855;color:#fff;}
  .efl-block select{
    width:100%;padding:12px 14px;border-radius:10px;border:1px solid var(--line);
    background:#120f26;color:var(--text);font-size:15px;appearance:none;
  }
  .efl-block.invalid select{border-color:#f05b5b;box-shadow:0 0 0 1px #f05b5b;}
  .efl-error{color:#f05b5b;font-size:12px;min-height:16px;margin-top:6px;}

  /* Editor screen */
  .editor-tabs{display:flex;gap:6px;overflow-x:auto;margin-bottom:16px;padding-bottom:2px;}
  .editor-tab{
    flex-shrink:0;padding:8px 14px;border-radius:20px;border:1px solid var(--line);
    background:var(--panel);color:var(--muted);font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;
  }
  .editor-tab.active{background:linear-gradient(90deg,var(--pl-magenta),var(--pl-violet));color:#fff;border-color:transparent;}
  .editor-row{
    display:flex;gap:8px;align-items:center;background:var(--panel);border:1px solid var(--line);
    border-radius:10px;padding:8px 10px;margin-bottom:6px;
  }
  .editor-row input[type=text]{flex:1;margin-top:0;padding:8px 10px;font-size:14px;}
  .editor-row input[type=number]{
    width:64px;padding:8px 6px;border-radius:10px;border:1px solid var(--line);
    background:#120f26;color:var(--text);font-size:14px;text-align:center;margin-top:0;
  }
  .editor-row label{font-size:10px;color:var(--muted);text-transform:uppercase;flex-shrink:0;}

  /* Instructions modal */
  .modal-backdrop{
    position:fixed;inset:0;background:rgba(6,5,16,.72);backdrop-filter:blur(2px);
    display:flex;align-items:center;justify-content:center;z-index:100;
    padding:20px;
    opacity:0;pointer-events:none;transition:opacity .2s ease;
  }
  .modal-backdrop.active{opacity:1;pointer-events:auto;}
  .modal-card{
    width:100%;max-width:640px;background:linear-gradient(180deg,var(--panel2),var(--panel));
    border:1px solid var(--line);border-radius:22px;padding:26px 22px 22px;
    max-height:88vh;overflow-y:auto;transform:scale(.96);opacity:0;transition:transform .25s ease, opacity .25s ease;
  }
  .modal-backdrop.active .modal-card{transform:scale(1);opacity:1;}
  .modal-card h3{font-size:21px;margin:0 0 4px;font-weight:800;}
  .modal-card .modal-sub{color:var(--muted);font-size:13px;margin:0 0 18px;}
  .modal-step{display:flex;gap:12px;margin-bottom:16px;}
  .modal-step .num{
    flex-shrink:0;width:26px;height:26px;border-radius:50%;background:var(--panel2);border:1px solid var(--line);
    display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:var(--pl-cyan);
  }
  .modal-step .txt{font-size:14px;line-height:1.5;color:var(--text);}
  .modal-step .txt b{color:var(--text);}
  .modal-divider{height:1px;background:var(--line);margin:18px 0;}
  .modal-card .btn{margin-top:4px;}
  .pw-input{
    width:100%;padding:14px 16px;border-radius:12px;border:1px solid var(--line);
    background:#120f26;color:var(--text);font-size:16px;margin-top:4px;letter-spacing:.08em;
  }
  .pw-error{color:#f05b5b;font-size:12px;min-height:16px;margin-top:8px;}
</style>
</head>
<body>
<div class="wrap">

  <div class="brand">
    <h1><img src="data:image/png;base64,
